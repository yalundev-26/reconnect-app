# ── Brevo (browser-side — used by landing page in local dev only) ─────────────
# In production the form calls /api/submit (server-side) — VITE_ vars not needed there
VITE_BREVO_API_KEY=your-brevo-api-key-here
VITE_BREVO_LIST_ID=your-list-id-here

# ── Brevo (server-side — used by api/submit.ts and api/telegram.ts) ──────────
BREVO_API_KEY=your-brevo-api-key-here
BREVO_LIST_ID=your-list-id-here

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Group ID — the group that receives new lead notifications
# Find it: add @userinfobot to your group, it will print the group ID
TELEGRAM_GROUP_ID=-5247644513
