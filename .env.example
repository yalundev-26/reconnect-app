# ── Brevo (browser-side — used by landing page in local dev only) ─────────────
VITE_BREVO_API_KEY=your-brevo-api-key-here
VITE_BREVO_LIST_ID=3

# ── Brevo (server-side — used by api/submit.ts, api/profile.ts) ──────────────
BREVO_API_KEY=your-brevo-api-key-here
BREVO_LIST_ID=3

# Email sender — must be a verified sender in your Brevo account
BREVO_SENDER_EMAIL=you@yourdomain.com
BREVO_SENDER_NAME=SyiyQ

# ── Token signing (any random string — keep it secret) ────────────────────────
TOKEN_SECRET=replace-this-with-a-random-secret-string

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_GROUP_ID=-5247644513
